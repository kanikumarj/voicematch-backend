# ─────────────────────────────────────────────────────────────────────────────
# Voice Match — Environment Variables
# Copy to .env and fill all values before starting the server.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development                     # development | production
CLIENT_ORIGIN=http://localhost:5173      # production: https://yourdomain.com

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://voice_user:changeme@localhost:5432/voice_match

# ── Cache (Redis) ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_byte_random_hex

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get API key from https://resend.com — free tier: 3000 emails/month
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=VoiceMatch <noreply@yourdomain.com>
APP_URL=http://localhost:5173             # production: https://yourdomain.com

# ── TURN Server ───────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TURN_SECRET=replace_with_strong_random_secret
TURN_URL=turn:your-server-ip:3478        # e.g. turn:1.2.3.4:3478
TURN_REALM=voicematch.local

# ── YouTube Search (Optional) ────────────────────────────────────────────────
# Get API key from https://console.cloud.google.com → YouTube Data API v3
# If not set, music search tab shows "unavailable" — URL paste still works
YOUTUBE_API_KEY=

# ── Error Tracking (Sentry) ───────────────────────────────────────────────────
# Get DSN from https://sentry.io — free tier available
SENTRY_DSN_BACKEND=https://xxx@oNNNN.ingest.sentry.io/NNNN

# ── Frontend environment (Vite — prefix VITE_) ────────────────────────────────
# These are embedded at build time — do NOT put secrets here
# Set real values in Netlify Dashboard → Environment Variables
VITE_API_URL=http://localhost:4000
VITE_SOCKET_URL=http://localhost:4000
VITE_APP_NAME=VoiceMatch
VITE_ENV=development
VITE_SENTRY_DSN=https://xxx@oNNNN.ingest.sentry.io/NNNN
