{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/admin-api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!api|admin-api).*)",
      "destination": "/index.html"
    }
  ]
}
